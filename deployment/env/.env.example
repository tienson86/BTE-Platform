# BTE Platform environment template (WP17)
# Copy to .env or export before starting services.

# Public / UI → API base URL
BTE_API_BASE_URL=http://127.0.0.1:8000

# Persistence backend: json | sqlite | postgres
BTE_STORAGE_BACKEND=json

# Optional absolute/relative paths
BTE_DATA_DIR=applications/data
BTE_LICENSE_PATH=applications/data/licenses.json
BTE_REPORT_PATH=reports
BTE_SQLITE_PATH=applications/data/bte.sqlite3

# Logging
BTE_LOG_LEVEL=INFO

# JWT (API) — change in production
BTE_JWT_SECRET=change-me-in-production

# Bind address / ports (per process)
HOST=127.0.0.1
PORT=8000
API_PORT=8000
ADMIN_PORT=8080
PORTAL_PORT=8081
