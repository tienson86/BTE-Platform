{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bte-platform/schema/snapshots/score_engine/schema.json",

  "title": "Score Engine Snapshot",
  "description": "Snapshot generated by Score Engine.",

  "type": "object",

  "additionalProperties": false,

  "required": [
    "case_id",
    "score"
  ],

  "properties": {

    "case_id": {
      "type": "string"
    },

    "score": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "total"
      ],

      "properties": {

        "strength": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },

        "pattern": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },

        "useful_god": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },

        "ten_gods": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },

        "shen_sha": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },

        "luck": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },

        "total": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }

      }

    }

  }

}
