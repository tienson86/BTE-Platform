{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bte-platform/schema/snapshots/report_engine/schema.json",

  "title": "Report Engine Snapshot",
  "description": "Snapshot generated by Report Engine.",

  "type": "object",

  "additionalProperties": false,

  "required": [
    "case_id",
    "generated_at",
    "report"
  ],

  "properties": {

    "case_id": {
      "type": "string"
    },

    "generated_at": {
      "type": "string",
      "format": "date-time"
    },

    "language": {
      "type": "string"
    },

    "report": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "title",
        "content"
      ],

      "properties": {

        "title": {
          "type": "string"
        },

        "content": {
          "type": "string"
        },

        "sections": {

          "type": "array",

          "items": {
            "type": "string"
          }

        }

      }

    },

    "markdown": {
      "type": "string"
    },

    "html": {
      "type": "string"
    },

    "pdf": {
      "type": "string"
    }

  }

}
