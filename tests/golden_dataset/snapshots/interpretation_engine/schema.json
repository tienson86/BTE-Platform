{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bte-platform/schema/snapshots/interpretation_engine/schema.json",

  "title": "Interpretation Engine Snapshot",
  "description": "Snapshot generated by Interpretation Engine.",

  "type": "object",

  "additionalProperties": false,

  "required": [
    "case_id",
    "interpretation"
  ],

  "properties": {

    "case_id": {
      "type": "string"
    },

    "interpretation": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "summary"
      ],

      "properties": {

        "summary": {
          "type": "string"
        },

        "personality": {
          "type": "string"
        },

        "career": {
          "type": "string"
        },

        "wealth": {
          "type": "string"
        },

        "marriage": {
          "type": "string"
        },

        "health": {
          "type": "string"
        },

        "children": {
          "type": "string"
        },

        "luck": {
          "type": "string"
        },

        "notes": {

          "type": "array",

          "items": {
            "type": "string"
          }

        }

      }

    }

  }

}
