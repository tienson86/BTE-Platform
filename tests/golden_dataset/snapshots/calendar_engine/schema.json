{
    "version": "1.0",
    "engine": "calendar_engine",

    "required": [
        "solar_datetime",
        "lunar_datetime",
        "julian_day",
        "solar_term",
        "timezone"
    ],

    "properties": {

        "solar_datetime": "string",

        "lunar_datetime": "string",

        "timezone": "string",

        "julian_day": "number",

        "true_solar_time": "string",

        "solar_term": "string",

        "season": "string",

        "year_index": "integer",

        "month_index": "integer",

        "day_index": "integer",

        "hour_index": "integer"

    }
}
