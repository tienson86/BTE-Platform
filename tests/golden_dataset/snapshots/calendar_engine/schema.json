{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bte-platform/schema/snapshots/calendar_engine/schema.json",

  "title": "Calendar Engine Snapshot",
  "description": "Snapshot generated by Calendar Engine.",

  "type": "object",

  "additionalProperties": false,

  "required": [
    "case_id",
    "solar",
    "lunar",
    "calendar"
  ],

  "properties": {

    "case_id": {
      "type": "string"
    },

    "solar": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "datetime"
      ],

      "properties": {

        "datetime": {
          "type": "string",
          "format": "date-time"
        },

        "timezone": {
          "type": "string"
        }

      }

    },

    "lunar": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "year",
        "month",
        "day"
      ],

      "properties": {

        "year": {
          "type": "integer"
        },

        "month": {
          "type": "integer"
        },

        "day": {
          "type": "integer"
        },

        "leap_month": {
          "type": "boolean"
        }

      }

    },

    "calendar": {

      "type": "object",

      "additionalProperties": false,

      "required": [

        "julian_day",

        "solar_term"

      ],

      "properties": {

        "julian_day": {

          "type": "number"

        },

        "true_solar_time": {

          "type": "string"

        },

        "solar_term": {

          "type": "string"

        },

        "season": {

          "type": "string"

        }

      }

    }

  }

}
