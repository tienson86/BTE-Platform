{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bte-platform/schema/snapshots/bazi_engine/schema.json",

  "title": "BTE Bazi Engine Snapshot",
  "description": "Snapshot generated by Bazi Engine.",

  "type": "object",
  "additionalProperties": false,

  "required": [
    "case_id",
    "pillars",
    "day_master",
    "hidden_stems",
    "five_elements",
    "ten_gods"
  ],

  "properties": {

    "case_id": {
      "type": "string",
      "pattern": "^case_[0-9]{4}$"
    },

    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "year",
        "month",
        "day",
        "hour"
      ],
      "properties": {

        "year": {
          "$ref": "#/$defs/pillar"
        },

        "month": {
          "$ref": "#/$defs/pillar"
        },

        "day": {
          "$ref": "#/$defs/pillar"
        },

        "hour": {
          "$ref": "#/$defs/pillar"
        }

      }
    },

    "day_master": {
      "type": "string",
      "enum": [
        "giap",
        "at",
        "binh",
        "dinh",
        "mau",
        "ky",
        "canh",
        "tan",
        "nham",
        "quy"
      ]
    },

    "hidden_stems": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "year",
        "month",
        "day",
        "hour"
      ],
      "properties": {

        "year": {
          "$ref": "#/$defs/hiddenStemList"
        },

        "month": {
          "$ref": "#/$defs/hiddenStemList"
        },

        "day": {
          "$ref": "#/$defs/hiddenStemList"
        },

        "hour": {
          "$ref": "#/$defs/hiddenStemList"
        }

      }
    },

    "five_elements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {

        "kim": {
          "type": "integer"
        },

        "moc": {
          "type": "integer"
        },

        "thuy": {
          "type": "integer"
        },

        "hoa": {
          "type": "integer"
        },

        "tho": {
          "type": "integer"
        }

      }
    },

    "ten_gods": {
      "type": "object",
      "additionalProperties": false,

      "required": [
        "year",
        "month",
        "day",
        "hour"
      ],

      "properties": {

        "year": {
          "$ref": "#/$defs/tenGod"
        },

        "month": {
          "$ref": "#/$defs/tenGod"
        },

        "day": {
          "$ref": "#/$defs/tenGod"
        },

        "hour": {
          "$ref": "#/$defs/tenGod"
        }

      }
    },

    "nayin": {

      "type": "object",

      "additionalProperties": false,

      "properties": {

        "year": {
          "type": "string"
        },

        "month": {
          "type": "string"
        },

        "day": {
          "type": "string"
        },

        "hour": {
          "type": "string"
        }

      }

    },

    "twelve_growth": {

      "type": "object",

      "additionalProperties": false,

      "properties": {

        "year": {
          "type": "string"
        },

        "month": {
          "type": "string"
        },

        "day": {
          "type": "string"
        },

        "hour": {
          "type": "string"
        }

      }

    },

    "empty_void": {

      "type": "array",

      "items": {
        "type": "string"
      }

    },

    "combinations": {

      "type": "object",

      "additionalProperties": false,

      "properties": {

        "heavenly_stems": {

          "type": "array",

          "items": {
            "type": "string"
          }

        },

        "earthly_branches": {

          "type": "array",

          "items": {
            "type": "string"
          }

        }

      }

    },

    "conflicts": {

      "type": "object",

      "additionalProperties": false,

      "properties": {

        "heavenly_stems": {

          "type": "array",

          "items": {
            "type": "string"
          }

        },

        "earthly_branches": {

          "type": "array",

          "items": {
            "type": "string"
          }

        }

      }

    }

  },

  "$defs": {

    "pillar": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "stem",
        "branch"
      ],

      "properties": {

        "stem": {
          "type": "string"
        },

        "branch": {
          "type": "string"
        }

      }

    },

    "hiddenStem": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "stem",
        "weight"
      ],

      "properties": {

        "stem": {
          "type": "string"
        },

        "weight": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }

      }

    },

    "hiddenStemList": {

      "type": "array",

      "items": {
        "$ref": "#/$defs/hiddenStem"
      }

    },

    "tenGod": {

      "type": "string",

      "enum": [

        "ty_kien",
        "kiep_tai",

        "thuc_than",
        "thuong_quan",

        "thien_tai",
        "chinh_tai",

        "that_sat",
        "chinh_quan",

        "thien_an",
        "chinh_an"

      ]

    }

  }

}
