{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bte-platform/schema/golden_dataset/input_schema.json",

  "title": "BTE Golden Dataset Input Schema",
  "description": "Input schema for BTE Platform Golden Dataset.",

  "type": "object",
  "additionalProperties": false,

  "required": [
    "case_id",
    "description",
    "birth"
  ],

  "properties": {

    "case_id": {
      "type": "string",
      "pattern": "^case_[0-9]{4}$",
      "description": "Unique test case identifier."
    },

    "description": {
      "type": "string",
      "minLength": 1
    },

    "tags": {
      "type": "array",
      "description": "Optional labels for grouping test cases.",
      "items": {
        "type": "string"
      },
      "default": []
    },

    "birth": {

      "type": "object",
      "additionalProperties": false,

      "required": [
        "gender",
        "solar_datetime",
        "timezone",
        "location"
      ],

      "properties": {

        "gender": {
          "type": "string",
          "enum": [
            "male",
            "female"
          ]
        },

        "solar_datetime": {
          "type": "string",
          "format": "date-time",
          "description": "Gregorian birth datetime."
        },

        "timezone": {
          "type": "string",
          "description": "IANA timezone name."
        },

        "location": {

          "type": "object",
          "additionalProperties": false,

          "required": [
            "country",
            "province",
            "district",
            "latitude",
            "longitude"
          ],

          "properties": {

            "country": {
              "type": "string"
            },

            "province": {
              "type": "string"
            },

            "district": {
              "type": "string"
            },

            "latitude": {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },

            "longitude": {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            }

          }

        }

      }

    },

    "options": {

      "type": "object",
      "additionalProperties": false,

      "properties": {

        "calendar": {

          "type": "object",
          "additionalProperties": false,

          "properties": {

            "calendar_type": {
              "type": "string",
              "enum": [
                "solar",
                "lunar"
              ],
              "default": "solar"
            },

            "use_true_solar_time": {
              "type": "boolean",
              "default": true
            },

            "use_dst": {
              "type": "boolean",
              "default": false
            }

          }

        },

        "engine": {

          "type": "object",
          "additionalProperties": false,

          "properties": {

            "language": {
              "type": "string",
              "default": "vi"
            },

            "rule_database": {
              "type": "string",
              "default": "v1.0"
            },

            "output_format": {
              "type": "string",
              "enum": [
                "json",
                "markdown",
                "html"
              ],
              "default": "json"
            }

          }

        }

      }

    }

  }

}
