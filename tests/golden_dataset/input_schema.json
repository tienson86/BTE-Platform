{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bte-platform/schema/golden_dataset/input_schema.json",

  "title": "BTE Golden Dataset Input Schema",
  "description": "Schema for input test cases of BTE Platform.",

  "type": "object",

  "additionalProperties": false,

  "required": [
    "case_id",
    "description",
    "chart"
  ],

  "properties": {

    "case_id": {
      "type": "string",
      "pattern": "^case_[0-9]{4}$",
      "description": "Unique Golden Dataset case id."
    },

    "description": {
      "type": "string",
      "minLength": 1
    },

    "tags": {

      "type": "array",

      "items": {
        "type": "string"
      },

      "default": []

    },

    "chart": {

      "type": "object",

      "additionalProperties": false,

      "required": [

        "gender",

        "year",

        "month",

        "day",

        "hour"

      ],

      "properties": {

        "gender": {

          "type": "string",

          "enum": [

            "male",

            "female"

          ]

        },

        "year": {

          "$ref": "#/$defs/pillar"

        },

        "month": {

          "$ref": "#/$defs/pillar"

        },

        "day": {

          "$ref": "#/$defs/pillar"

        },

        "hour": {

          "$ref": "#/$defs/pillar"

        },

        "birth": {

          "type": "object",

          "additionalProperties": false,

          "properties": {

            "solar_datetime": {

              "type": "string",

              "format": "date-time"

            },

            "timezone": {

              "type": "string"

            },

            "longitude": {

              "type": "number"

            },

            "latitude": {

              "type": "number"

            },

            "place": {

              "type": "string"

            }

          }

        }

      }

    }

  },

  "$defs": {

    "pillar": {

      "type": "object",

      "additionalProperties": false,

      "required": [

        "stem",

        "branch"

      ],

      "properties": {

        "stem": {

          "type": "string",

          "enum": [

            "giap",

            "at",

            "binh",

            "dinh",

            "mau",

            "ky",

            "canh",

            "tan",

            "nham",

            "quy"

          ]

        },

        "branch": {

          "type": "string",

          "enum": [

            "ty",

            "suu",

            "dan",

            "mao",

            "thin",

            "ti",

            "ngo",

            "mui",

            "than",

            "dau",

            "tuat",

            "hoi"

          ]

        }

      }

    }

  }

}
