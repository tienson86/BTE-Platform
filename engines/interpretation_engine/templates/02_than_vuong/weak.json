        "enabled": true,
        "trigger": { "rule_ids": ["STR_WEAK"] },
        "text": "Nhật chủ thuộc trạng thái thân nhược, nội lực của mệnh cục tương đối yếu."
      },
      {
        "id": "TV_WEA_CON_002",
        "priority": 2,
        "style": "standard",
        "language": "vi",
        "enabled": true,
        "trigger": { "rule_ids": ["STR_WEAK"] },
        "text": "Qua tổng hợp các yếu tố trong mệnh cục, Nhật chủ được đánh giá là thân nhược."
      },
      {
        "id": "TV_WEA_CON_003",
        "priority": 3,
        "style": "professional",
        "language": "vi",
        "enabled": true,
        "trigger": { "rule_ids": ["STR_WEAK"] },
        "text": "Sức mạnh của Nhật chủ chưa đủ để cân bằng với các ngũ hành còn lại trong mệnh cục."
      },
      {
        "id": "TV_WEA_CON_004",
        "priority": 4,
        "style": "standard",
        "language": "vi",
        "enabled": true,
        "trigger": { "rule_ids": ["STR_WEAK"] },
        "text": "Khí lực của Nhật chủ ở mức thấp, cần thêm yếu tố sinh trợ để đạt trạng thái cân bằng."
      },
      {
        "id": "TV_WEA_CON_005",
        "priority": 5,
        "style": "professional",
        "language": "vi",
        "enabled": true,
        "trigger": { "rule_ids": ["STR_WEAK"] },
        "text": "Mệnh cục nghiêng về thân nhược, khả năng tự chống đỡ trước các yếu tố khắc tiết còn hạn chế."
      },
      {
        "id": "TV_WEA_CON_006",
        "priority": 6,
        "style": "standard",
        "language": "vi",
        "enabled": true,
        "trigger": { "rule_ids": ["STR_WEAK"] },
        "text": "Nhật chủ chưa có đủ trợ lực để hình thành thế thân vượng."
      },
      {
        "id": "TV_WEA_CON_007",
        "priority": 7,
        "style": "standard",
        "language": "vi",
        "enabled": true,
        "trigger": { "rule_ids": ["STR_WEAK"] },
        "text": "Tổng thể mệnh cục cho thấy Nhật chủ thiên về trạng thái thân nhược."
