      {
        "id": "TV_WEA_CON_008",
        "priority": 8,
        "style": "professional",
        "language": "vi",
        "enabled": true,
        "trigger": { "rule_ids": ["STR_WEAK"] },
        "text": "Cường độ của Nhật chủ thấp hơn mức cân bằng, vì vậy cần xét kỹ các yếu tố sinh phù."
      },
      {
        "id": "TV_WEA_CON_009",
