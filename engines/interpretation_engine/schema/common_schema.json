{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common_schema.json",
  "title": "BTE Common Types",
  "type": "object",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000
    },
    "enabled": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
