{
  "$schema": "https://json-schema.org/draft/2020-12/schema",

  "$id": "chapter_schema.json",

  "title": "Chapter Schema",

  "type": "object",

  "required": [

    "chapter_id",

    "title",

    "paragraphs"

  ],

  "properties": {

    "chapter_id": {
      "$ref": "common_schema.json#/$defs/id"
    },

    "title": {
      "$ref": "common_schema.json#/$defs/name"
    },

    "order": {

      "type": "integer",

      "minimum": 1,

      "default": 1

    },

    "paragraphs": {

      "type": "array",

      "minItems": 1,

      "items": {
        "$ref": "common_schema.json#/$defs/id"
      }

    },

    "description": {

      "type": "string"

    }

  },

  "additionalProperties": false
}
